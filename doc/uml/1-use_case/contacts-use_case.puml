@startuml contacts_use_case

left to right direction

actor Visiteur as v
actor Utilisateur as u

v <|-right- u

rectangle "Contacts" {
  usecase "Afficher des contacts fictifs" as UC1
  usecase "Ajouter un contact" as UC2
  usecase "Supprimer un contact" as UC3
  usecase "Modifier un contact" as UC4
  usecase "Envoyer un message" as UC5
  usecase "Voir ses messages" as UC6
  usecase "Se connecter" as UC7
}

v --> UC1
u --> UC2
u --> UC3
u --> UC4
u --> UC5
u --> UC6

UC2 ..> UC7 : <<include>>
UC3 ..> UC7 : <<include>>
UC4 ..> UC7 : <<include>>
UC5 ..> UC7 : <<include>>
UC6 ..> UC7 : <<include>>

@enduml